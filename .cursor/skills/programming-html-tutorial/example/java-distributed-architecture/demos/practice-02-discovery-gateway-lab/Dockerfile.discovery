# 多阶段构建：Eureka Discovery Server
FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /workspace
COPY shopflow/pom.xml shopflow/pom.xml
COPY shopflow/shopflow-common shopflow/shopflow-common
COPY shopflow/shopflow-discovery-server shopflow/shopflow-discovery-server
RUN mvn -f shopflow/pom.xml -pl shopflow-discovery-server -am -DskipTests package

FROM eclipse-temurin:21-jre
WORKDIR /app
COPY --from=build /workspace/shopflow/shopflow-discovery-server/target/shopflow-discovery-server-*.jar app.jar
EXPOSE 8761
ENTRYPOINT ["java", "-jar", "app.jar", "--spring.profiles.active=docker"]
