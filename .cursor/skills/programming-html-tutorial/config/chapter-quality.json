{
  "$schema": "chapter-quality policy for review-chapter.mjs (v3.0.0, single policy)",
  "quiz": {
    "requiredByDefault": true,
    "requireQuestionTypes": ["single", "multi", "fill"],
    "minQuestionsPerChapter": 4,
    "skipWhenUserExplicitlyDisabled": true,
    "requireSectionKeywordCoverage": false,
    "minSectionKeywordCoverageRatio": 0.5
  },
  "wordCount": {
    "minByChapterType": {
      "concept": null,
      "practice": null,
      "advanced": null
    }
  },
  "lines": {
    "countScope": "body-section-blocks",
    "minByChapterType": {
      "concept": 250,
      "practice": 250,
      "advanced": 250
    },
    "skipChapterIds": [],
    "countMode": "physical"
  },
  "demos": {
    "enabled": true,
    "requireDemoBoxReference": false,
    "minReadmeLines": 12,
    "requireDocLabAcceptanceCommand": true,
    "warnOrphanLabs": true,
    "requireReferencedFiles": true
  },
  "richness": {
    "minSectionBlocksMatchOutline": true,
    "minMermaidConcept": 1,
    "minCodeBlocksPractice": 1,
    "minPreBlocksConcept": 1,
    "minCompareOrTableConcept": 1,
    "minPresentationFormsPerSection": 0,
    "presentationForms": [
      "mermaid",
      "table",
      "pre",
      "learn-compare",
      "learn-scenario",
      "learn-faq",
      "code-block"
    ]
  },
  "terms": {
    "minSpansConcept": 8,
    "minSpansPractice": 5,
    "minUniqueIdsConcept": 5,
    "minUniqueIdsPractice": 3,
    "minPromptChars": 80,
    "theoryPhaseIds": ["basics", "advanced"],
    "requirePromptSemantics": true,
    "requirePromptContains": ["误区"],
    "forbidPromptPatterns": ["请解释什么是", "介绍一下什么是", "什么是…的定义"]
  },
  "mermaid": {
    "minCountConcept": 1,
    "minCountPractice": 0
  },
  "code": {
    "minBlocksConcept": 0,
    "minBlocksPractice": 1
  },
  "codeBlocks": {
    "requireStandardToolbar": true,
    "requireLanguageClass": true,
    "requireCopyButtonLabel": "复制代码"
  },
  "steps": {
    "minCount": 3,
    "maxCount": 8,
    "demoOverlapWarning": true
  },
  "practice": {
    "minSteps": 3,
    "maxSteps": 8,
    "stepsPerSectionRatio": 0.5,
    "stepsPerSectionRatioPractice": 0.6,
    "maxDemoOnlySteps": 1,
    "minIntroChars": 18,
    "minJudgmentAnswerChars": 8,
    "requireOperateDom": true,
    "requireJudgmentDom": true,
    "boilerplateIntroPatterns": [
      "先完成.*理解.*再用.*判断",
      "理解.*步骤.*判断.*检验"
    ],
    "boilerplateJudgmentPatterns": [
      "方案 A.*方案 B.*各写.*支持.*反对",
      "请各写.*1 条支持.*1 条反对"
    ]
  },
  "pedagogy": {
    "requiredForConceptChapters": true,
    "minConclusionBullets": 2,
    "requireJudgmentPractice": true,
    "requireMicroCheckConcept": true,
    "requireDemoBoxTitle": true,
    "requirePracticeSectionTitles": true
  },
  "forbiddenTopics": {
    "scanScopes": ["chapter", "quiz"],
    "defaultTopics": []
  },
  "emptyContent": {
    "maxConsecutivePlainParagraphLines": 0
  },
  "gateReport": {
    "defaultRelativeDir": ".course-quality"
  }
}
