[
  {
    "name": "query_order",
    "description": "查询 CorpAssist 商城订单状态与物流。用户提到订单号、发货、物流时使用。不要用于退款或创建工单。",
    "parameters": {
      "type": "object",
      "properties": {
        "order_id": { "type": "string", "description": "纯数字订单号" },
        "tenant_id": { "type": "string", "description": "租户 ID，从会话注入" }
      },
      "required": ["order_id", "tenant_id"]
    }
  },
  {
    "name": "create_ticket",
    "description": "在 ITSM 创建工单。用户明确要求建单、报障、提 ticket 时使用。需要 category 与 summary。",
    "parameters": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "enum": ["network", "hardware", "software", "access", "other"],
          "description": "工单分类"
        },
        "summary": { "type": "string", "description": "问题摘要，10-500 字" }
      },
      "required": ["category", "summary"]
    }
  }
]
