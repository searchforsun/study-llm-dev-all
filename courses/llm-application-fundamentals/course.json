  "terms": {
    "token": {
      "label": "Token",
      "prompt": "我在学习大模型应用基础（CorpAssist 企业智能助手）。请解释 Token 是什么、中英文与代码片段如何被切分计费，结合长文档问答说明为何上下文越长越贵，并给出一次请求 input/output Token 粗算示例与常见踩坑。"
    },
    "context-window": {
      "label": "上下文窗口",
      "prompt": "我在学习 LLM 应用（CorpAssist 多轮客服）。请解释 context window 的含义、超过上限时的滑动窗口/摘要截断策略，并说明如何在编排层为 system 提示、历史消息与 RAG 片段分配 Token 预算。"
    },
    "hallucination": {
      "label": "幻觉",
      "prompt": "我在学习大模型应用（CorpAssist 制度问答）。请解释幻觉是什么、与 RAG 的关系，举一个编造不存在条款的例子，并说明引用溯源、拒答阈值与人工复核如何组合降低合规风险。"
    },
    "temperature": {
      "label": "温度 temperature",
      "prompt": "我在学习 API 调用（CorpAssist）。请解释 temperature 与 top_p 对采样随机性的影响，对比智能客服（偏稳定）与营销文案（偏多样）的推荐参数区间，并说明误设高温导致政策话术漂移的风险。"
    },
    "rag": {
      "label": "RAG 检索增强生成",
      "prompt": "我在学习 LLM 应用架构（CorpAssist 知识库 S1）。请用通俗语言解释 RAG 的流程（索引-检索-生成）、与微调的区别，说明企业知识库问答为何首选 RAG，并给一个混合检索不相关时的排查清单（分块/Embedding/Rerank）。"
    },
    "agent": {
      "label": "Agent 智能体",
      "prompt": "我在学习 Agent（CorpAssist 办公自动化 S3）。请解释 Agent 与普通对话应用的区别（规划、工具调用、状态），举一个 ReAct 式「查日历→发邮件→记工单」流程，并说明工具调用失败、超时与步数预算的降级策略。"
    },
    "prompt-engineering": {
      "label": "提示词工程",
      "prompt": "我在学习 Prompt 工程（CorpAssist 客服 S2）。请解释 system 提示、Few-shot、CoT 在工程上的作用，说明政策话术模板应放在哪一层，并对比「只改 user 消息」与「改 system 提示」各自适用的场景与评测方法。"
    },
    "transformer": {
      "label": "Transformer（应用层）",
      "prompt": "我在学习大模型基础（应用开发者视角）。请直觉解释 Transformer 与 Attention（避免公式推导），说明自回归「逐 Token 生成」如何对应 API 流式输出，并说明为何长上下文仍需 RAG 而不是无限堆历史。"
    },
    "streaming": {
      "label": "流式输出 SSE",
      "prompt": "我在学习 API 集成（CorpAssist 网关）。请解释流式 SSE/chunk 与非流式调用的用户体验与实现差异，说明 Spring Cloud Gateway 转发流式时需关闭缓冲、设置读超时，以及断线重连对会话状态的影响。"
    },
    "fine-tuning": {
      "label": "微调",
      "prompt": "我在学习模型选型（CorpAssist）。请解释 SFT/LoRA 微调的适用场景、与 RAG/Prompt 的边界，说明知识库问答何时不应优先微调，并列举标注数据不足、评测缺失时强行微调的三类风险。"
    },
    "embedding": {
      "label": "向量 Embedding",
      "prompt": "我在学习 RAG 索引（CorpAssist 文档中心）。请解释文本 Embedding 的作用、与 BM25 关键词检索的区别，说明入库时模型选型要考虑的维度、中英文效果、更新成本，以及向量与对话模型分开计费的原因。"
    },
    "openai-compatible": {
      "label": "OpenAI 兼容协议",
      "prompt": "我在学习模型接入（CorpAssist 多模型网关）。请解释 OpenAI 兼容 API 的请求/响应形状，说明为何 Spring AI 与 Python httpx 可共用 base_url，并列举切换通义/DeepSeek/私有化时只需改哪些配置项。"
    }
  },
